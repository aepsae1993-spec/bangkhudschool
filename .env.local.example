# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Apps Script Web App URL (Drive bridge) ---
# Deploy apps-script/Code.gs ที่ https://script.google.com แล้วเอา /exec URL มาใส่
NEXT_PUBLIC_GAS_DRIVE_URL=https://script.google.com/macros/s/XXXXXX/exec
GAS_DRIVE_SECRET=put-a-long-random-secret-here-and-paste-same-in-apps-script

# --- ข้อมูลโรงเรียน (เปลี่ยนได้) ---
NEXT_PUBLIC_SCHOOL_NAME=โรงเรียนวัดบางขุด(อุ่นพิทยาคาร)
